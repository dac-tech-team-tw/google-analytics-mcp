# ============================================================
# GA4 MCP HTTP Server - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# On Cloud Run, set these via Secret Manager references or
# environment variables in the Cloud Run service configuration.

# ------------------------------------------------------------
# Google OAuth 2.0 (required for HTTP/OAuth mode)
# Create at: https://console.cloud.google.com/apis/credentials
# Application type: Web application
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# Base URL of this server (must match OAuth redirect URI config)
# Local dev: http://localhost:8000
# Cloud Run: https://your-service-xxxx-uc.a.run.app
BASE_URL=http://localhost:8000

# ------------------------------------------------------------
# Token Storage - GCS (required for HTTP/OAuth mode)
# The bucket must be private (no public access).
# Cloud Run SA needs roles/storage.objectAdmin on this bucket.
# ------------------------------------------------------------
GCS_BUCKET_NAME=your-project-ga4-mcp-tokens

# Fernet symmetric encryption key for tokens stored in GCS.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ------------------------------------------------------------
# JWT Signing (required for HTTP/OAuth mode)
# Used to sign FastMCP session tokens.
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ------------------------------------------------------------
JWT_SIGNING_KEY=

# ------------------------------------------------------------
# Server configuration (optional)
# ------------------------------------------------------------
# Port to listen on (Cloud Run sets this automatically)
PORT=8000
